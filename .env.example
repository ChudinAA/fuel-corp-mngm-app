# ============================================================
# Aviation Fuel Management System — Environment Variables
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
# Имя базы данных
POSTGRES_DB=avfuel

# Пользователь базы данных
POSTGRES_USER=avfuel

# ОБЯЗАТЕЛЬНО: пароль базы данных (минимум 24 символа, случайные)
# Генерация: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─── Application ─────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО: секрет для подписи сессий (минимум 32 символа, случайные)
# Генерация: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_STRONG_SESSION_SECRET_HERE

# Порт, на котором приложение будет доступно снаружи контейнера
APP_PORT=5000

# Режим отладки сетевых запросов (true/false)
DEBUG_NETWORK=false

# ─── Backup ──────────────────────────────────────────────────
# Сколько дней хранить резервные копии (полные бэкапы)
BACKUP_RETENTION_DAYS=30

# Сколько дней хранить архивные бэкапы (audit_log, операционные таблицы)
BACKUP_ARCHIVE_RETENTION_DAYS=365

# Расписание бэкапов в формате cron (по умолчанию: каждый день в 02:00)
BACKUP_SCHEDULE=0 2 * * *

# Директория для хранения бэкапов (монтируется в контейнер)
# BACKUP_DIR=./backups
