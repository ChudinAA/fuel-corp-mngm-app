# =============================================================================
# Server 1: Application Server — переменные окружения
# Файл: /opt/avfuel/.env (chmod 600)
# =============================================================================

# ─── Подключение к БД (Server 2) ─────────────────────────────────────────────
# Генерация: openssl rand -base64 32
DATABASE_URL=postgresql://avfuel:STRONG_DB_PASSWORD@DB_SERVER_IP:5432/avfuel

# ─── Session Secret ───────────────────────────────────────────────────────────
# Генерация: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_STRONG_SESSION_SECRET_HERE

# ─── Прочие настройки ────────────────────────────────────────────────────────
DEBUG_NETWORK=false

# IP сервера мониторинга (опционально, для метрик)
# MONITORING_SERVER=MONITORING_SERVER_IP
