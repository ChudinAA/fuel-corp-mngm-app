# =============================================================================
# Server 3: Monitoring + Backup Server — переменные окружения
# Файл: /opt/avfuel-monitoring/.env (chmod 600)
# =============================================================================

# ─── IP адреса других серверов (для Prometheus scrape) ───────────────────────
APP_SERVER_IP=APP_SERVER_IP_HERE
DB_SERVER_IP=DB_SERVER_IP_HERE

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
# Генерация: openssl rand -base64 24
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_ROOT_URL=http://MONITORING_SERVER_IP:3000

# ─── SMTP для email алертов (опционально) ────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=alerts@company.com
SMTP_PASSWORD=smtp_app_password
SMTP_FROM=alerts@company.com

# ─── Telegram алерты ─────────────────────────────────────────────────────────
# Создать бота: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# Узнать chat_id: написать боту /start, затем https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ─── Холодное хранилище (rclone) ─────────────────────────────────────────────
# Имя remote из docker/monitoring/rclone/rclone.conf
RCLONE_REMOTE=s3-cold
RCLONE_BUCKET=avfuel-backups
# Час синхронизации в cold storage (0-23)
COLD_STORAGE_SYNC_HOUR=3
# День недели для глубокой проверки бэкапа (0=воскресенье)
BACKUP_VERIFY_DAY=0
# Хранить локальные архивы N дней (старше — удалять, т.к. уже в cold storage)
ARCHIVE_OLDER_THAN_DAYS=30

# ─── Проверка бэкапов с подключением к DB Server (опционально) ───────────────
# Если задано — verify-backup.sh восстановит бэкап во временную БД на DB Server
# VERIFY_PG_HOST=DB_SERVER_IP
# VERIFY_PG_USER=avfuel
# VERIFY_PG_PASSWORD=SAME_AS_POSTGRES_PASSWORD

# ─── SSH ключ для приёма rsync от DB Server ──────────────────────────────────
BACKUP_SSH_KEY=./docker/monitoring/backup-manager/id_rsa
