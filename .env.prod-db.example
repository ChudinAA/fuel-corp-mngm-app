# =============================================================================
# Server 2: Database Server — переменные окружения
# Файл: /opt/avfuel-db/.env (chmod 600)
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=avfuel
POSTGRES_USER=avfuel
# Генерация: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Привязка PostgreSQL (0.0.0.0 = слушает на всех интерфейсах)
# Защиту обеспечивает firewall (ufw allow from APP_SERVER_IP to any port 5432)
DB_BIND_IP=0.0.0.0

# Привязка Postgres Exporter (для Prometheus с Server 3)
# ufw allow from MON_SERVER_IP to any port 9187
METRICS_BIND_IP=0.0.0.0

# ─── Бэкапы ──────────────────────────────────────────────────────────────────
# Сколько дней хранить локальные бэкапы (короткий retention — Server 3 хранит дольше)
BACKUP_RETENTION_DAYS=7

# Параметры rsync → Server 3 (Monitoring + Backup Server)
BACKUP_REMOTE_HOST=MONITORING_SERVER_IP
BACKUP_REMOTE_USER=backup
BACKUP_REMOTE_PATH=/backups/avfuel

# Путь к SSH-ключу для rsync (генерация: ssh-keygen -t ed25519 -f docker/db-server/id_rsa -N "")
SSH_KEY_PATH=./docker/db-server/id_rsa
